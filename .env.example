# Database configuration
# For development (SQLite): leave unset or set to 'sqlite'
# For production (PostgreSQL): set to 'postgresql'
DB_TYPE=sqlite

# PostgreSQL connection string (required when DB_TYPE=postgresql)
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/morondartva

# Merchant phone numbers (paiement mobile)
# Laissez vide ou commentez pour utiliser les valeurs par défaut
MVOLA_MERCHANT_PHONE=0345148152
ORANGE_MONEY_MERCHANT_PHONE=0326180018
AIRTEL_MONEY_MERCHANT_PHONE=0330000000

# Server configuration
HOST=0.0.0.0
PORT=8000
HTTPS_PORT=8443
